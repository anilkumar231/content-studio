# ============================================================
# Content Studio - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
# ============================================================

# --- Supabase (Database) ---
# Create a free project at https://supabase.com
# Find these in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (AI - Script writing, research, repurposing) ---
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- YouTube Data API v3 (Analytics, research, peer tracking) ---
# Enable at https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Create credentials > API Key
YOUTUBE_API_KEY=

# Your YouTube channel ID (find it at https://www.youtube.com/account_advanced)
YOUTUBE_CHANNEL_ID=

# --- Google Gemini (Thumbnail generation) ---
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Deepgram (Audio transcription for shorts) ---
# Sign up at https://deepgram.com and get a key from the dashboard
DEEPGRAM_API_KEY=

# --- Blotato (Social media publishing) ---
# Sign up at https://blotato.com and get your API key
BLOTATO_API_KEY=

# --- Dashboard Password (REQUIRED) ---
# Choose a password to protect your dashboard. No default - you must set one.
DASHBOARD_PASSWORD=
